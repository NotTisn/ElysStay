# Copy this file to .env and fill in secure values
#
# For production (behind Caddy with auto-HTTPS on a real domain):
#   DOMAIN=elysstay.example.com
#   FRONTEND_URL=https://elysstay.example.com
#   API_PUBLIC_URL=https://elysstay.example.com/api/v1
#   KEYCLOAK_PUBLIC_URL=https://elysstay.example.com
#   KEYCLOAK_HOSTNAME=elysstay.example.com

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=ElysStay

# ── Keycloak ──────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
# KC_HOSTNAME — Keycloak uses this for token issuer URL
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_BE_CLIENT_SECRET=pTk5xWtGqAGRnd39yzFZcX8zQGbduPCu

# ── Public URLs ───────────────────────────────────────────
# How the browser reaches each service (through Caddy reverse proxy).
# FRONTEND_URL: used by backend CORS
# API_PUBLIC_URL: baked into FE bundle as NEXT_PUBLIC_API_URL (include /api/v1)
# KEYCLOAK_PUBLIC_URL: baked into FE bundle as NEXT_PUBLIC_KEYCLOAK_URL + used for ValidIssuer
FRONTEND_URL=http://localhost
API_PUBLIC_URL=http://localhost/api/v1
KEYCLOAK_PUBLIC_URL=http://localhost

# ── Caddy domain ─────────────────────────────────────────
# Real domain → auto HTTPS via Let's Encrypt
# "localhost" → HTTP-only (for local testing)
DOMAIN=localhost
